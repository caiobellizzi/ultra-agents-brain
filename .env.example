# ultra-agents-brain deployment settings.
# Copy to .env on the VPS and fill real secrets there only.

UAB_SERVICE_USER=uabrain
UAB_PROJECT_ROOT=/opt/ultra-agents-brain
UAB_LOG_DIR=/var/log/ultra-agents-brain

LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest
LITELLM_PORT=4000
LITELLM_BASE_URL=http://127.0.0.1:4000/v1
LITELLM_MASTER_KEY=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# LM Studio API (OpenAI-compatible)
# Local dev:  LM_STUDIO_API_BASE=http://localhost:1234/v1
# VPS via LM Link: LM_STUDIO_API_BASE=<lm-link-endpoint-from-lm-studio-ui>
LM_STUDIO_API_BASE=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
# Model ID as shown in LM Studio (e.g. qwen3-32b-mlx, llama-3.3-70b-instruct)
LM_STUDIO_MODEL=lm-studio-primary
LM_STUDIO_FAST_MODEL=lm-studio-fast

HERMES_IMAGE=ghcr.io/nousresearch/hermes-agent:v2026.5.16
HERMES_HTTP_PORT=8787
HERMES_CONFIG_DIR=/opt/ultra-agents-brain/hermes
HERMES_SKILLS_DIR=/opt/ultra-agents-brain/hermes/skills
HERMES_STATE_DIR=/var/lib/ultra-agents-brain/hermes
HERMES_TELEGRAM_WEBHOOK_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

SECOND_BRAIN_DIR=/srv/second-brain
COST_LEDGER=/srv/second-brain/_system/cost-ledger.md
DAILY_COST_CAP_USD=20
ALLOW_DIRTY_VAULT=0
HEALTH_NOTIFY_ON_SUCCESS=0

CRAWL4AI_MCP_URL=http://127.0.0.1:11235/mcp

# Vault sync prerequisites.
HERMES_RELEASE_TAG=v2026.5.16
VAULT_REMOTE_URL=
VAULT_VPS_PATH=
VAULT_MAC_PATH=
VAULT_DEFAULT_BRANCH=main
VAULT_COST_WARNING_USD=16
